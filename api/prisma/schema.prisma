generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model category {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  description String?
  plans       plans[]
}

model clients {
  id              Int               @id @default(autoincrement())
  first_name      String            @db.VarChar(100)
  last_name       String            @db.VarChar(100)
  email           String            @unique @db.VarChar(255)
  phone           String?           @db.VarChar(20)
  dob             DateTime?         @db.Date
  gender          String?           @db.VarChar(20)
  address         String?
  medical_notes   String?
  planes_clientes planes_clientes[]
}

model planes_clientes {
  id           Int       @id @default(autoincrement())
  plan_id      Int
  client_id    Int
  fecha_inicio DateTime? @db.Date
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  pagos        pagos[]
  clients      clients   @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  plans        plans     @relation(fields: [plan_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model plans {
  id              Int               @id @default(autoincrement())
  category_id     Int
  name            String            @db.VarChar(255)
  description     String?
  price           Decimal           @db.Decimal(10, 2)
  duration        Int
  monthly_payment Boolean?
  planes_clientes planes_clientes[]
  category        category          @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model pagos {
  id                 Int             @id @default(autoincrement())
  planes_clientes_id Int
  pago_fecha         DateTime?       @db.Timestamp(6)
  concepto           String          @db.VarChar(255)
  periodo_inicio     DateTime        @db.Date
  periodo_fin        DateTime        @db.Date
  cantidad           Decimal         @db.Decimal(10, 2)
  metodo_pago_id     Int?
  metodos_pago       metodos_pago?   @relation(fields: [metodo_pago_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  planes_clientes    planes_clientes @relation(fields: [planes_clientes_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model metodos_pago {
  id     Int     @id @default(autoincrement())
  metodo String  @db.VarChar(255)
  pagos  pagos[]
}
