generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model category {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  description String?
}

model plans {
  id          Int     @id @default(autoincrement())
  category_id Int
  name        String  @db.VarChar(255)
  description String?
  price       Decimal @db.Decimal(10, 2)
  duration    Int
}
